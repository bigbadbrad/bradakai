{
  "service": "bradakai-agent-product-api",
  "description": "Agent-friendly product data for bradakai.com bucket hats.",
  "endpoints": {
    "productBySlug": {
      "method": "GET",
      "pathTemplate": "/api/agent/products/{slug}",
      "slugSource": "Last segment of https://bradakai.com/products/{slug}",
      "exampleRequest": "GET https://bradakai.com/api/agent/products/frayed-edge-bucket-hat-light-blue-denim",
      "responseShape": "AgentProduct"
    }
  },
  "schemas": {
    "AgentProduct": {
      "id": "string",
      "handle": "string",
      "slug": "string",
      "title": "string",
      "description": "string",
      "detailBullets": ["string"],
      "rating": {
        "value": "number",
        "count": "number"
      },
      "images": [
        {
          "url": "string",
          "altText": "string",
          "role": "hero | gallery | lifestyle | detail"
        }
      ],
      "variants": [
        {
          "id": "string",
          "shopifyVariantId": "string",
          "sku": "string",
          "title": "string",
          "available": "boolean",
          "price": {
            "amount": "string",
            "currencyCode": "string"
          },
          "options": [
            { "name": "string", "value": "string" }
          ],
          "image": {
            "url": "string",
            "altText": "string"
          }
        }
      ],
      "attributes": {
        "shippingNote": "string",
        "returnsNote": "string",
        "lineTitle": "string"
      }
    }
  }
}

